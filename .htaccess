
# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress
RewriteCond %{HTTP_HOST} ^realmaestranzahotel\.com$ [OR]
RewriteCond %{HTTP_HOST} ^www\.realmaestranzahotel\.com$
RewriteRule ^/?$ "https\:\/\/realmaestranzahotel\.com\/index\.html" [R=301,L]

